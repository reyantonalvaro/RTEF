cc = clang
cflags = -std=c11 -Wall -Wextra -O2

rule compile
  command = $cc $cflags -o $out $in
  description = Compiling $in

rule run
  command = ./$in
  description = Running $in
  pool = console

rule clean_rule
  command = rm -f app
  description = Cleaning build artifacts

build app: compile src/main.c

build run: run app

build clean: clean_rule
  pool = console

default app
